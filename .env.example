VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# Tawk live chat — use YOUR active property/widget from dashboard.tawk.to
# IMPORTANT: Old IDs 6a18d83c6a53b51c391fd9f9 / 1jpogpcfe no longer work (404).
# If unset locally, code defaults below are used. On Vercel, env vars OVERRIDE defaults at build time.
VITE_TAWK_PROPERTY_ID=6a19a97f2951b91c34153174
VITE_TAWK_WIDGET_ID=1jpq3s7dj
# Set to false to disable Tawk live chat
# VITE_TAWK_ENABLED=true
# In Tawk dashboard: Administration → Chat Widget → Availability Restriction
# Add safapaygroup.com and www.safapaygroup.com (no https://) if domain restriction is ON

# Set to false to disable the free Google Translate website widget
VITE_GOOGLE_TRANSLATE_ENABLED=true
